{
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "sqlite3": "^5.1.7",
    "zod": "^3.25.42",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "http-status": "^1.7.4",
    "mongoose": "^8.4.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "dotenv": "^16.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "@eslint/js": "^9.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.9.0"
  },

  "scripts": {
    "start": "tsx watch server.ts",
    "dev": "tsx watch server.ts",

    "migrate": "node --loader ts-node/esm ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "ts-node --esm ./node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "ts-node --esm ./node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.ts",
    "migrate:status": "ts-node --esm ./node_modules/knex/bin/cli.js migrate:status --knexfile knexfile.ts",

    "seed": "ts-node --esm ./node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
    "seed:make": "ts-node --esm ./node_modules/knex/bin/cli.js seed:make --knexfile knexfile.ts"
  },
  "type": "module"
}


