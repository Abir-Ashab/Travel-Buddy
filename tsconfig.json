{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ES2020",
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src/**/*"
    ],
    "ts-node": {
        "esm": true
    }
}