{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ES2020",
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "types": ["jest", "node"]
    },
    "include": [
        "src/**/*"
, "tests/utils"    ],
    "ts-node": {
        "esm": true
    },
    "exclude": ["node_modules", "dist"]
}