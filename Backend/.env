# Environment Variables for Travel Buddy


NODE_ENV=development
PORT=3000

# Database Configuration
DB_ORM=knex
# DB_TYPE=sqlite

# SQLite Configuration (easiest to start with)
# SQLITE_PATH=./database.sqlite

# PostgreSQL Configuration (uncomment if using PostgreSQL)
DB_TYPE=postgresql
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=travel app
PG_USER=postgres
PG_PASSWORD=312889
PG_SSL=false

# MySQL Configuration (uncomment if using MySQL)
# DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=myapp_dev
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password

# Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
BCRYPT_SALT_ROUNDS=5
JWT_ACCESS_SECRET=abir-ashab-niloy-cefalo-bangladesh-ltd
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=abir-ashab-niloy-cefalo-bangladesh-ltd-1315
JWT_REFRESH_EXPIRES_IN=1y
